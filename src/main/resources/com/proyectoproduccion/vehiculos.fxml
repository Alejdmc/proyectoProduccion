<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" style="-fx-padding:20; -fx-background-color:#f4f6f8;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.proyectoproduccion.Controlador.VehiculosController">

    <HBox alignment="CENTER_LEFT" spacing="15">

        <Label fx:id="lblVehiculos" text="VEHÍCULOS">
            <font>
                <Font size="22" />
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS" />

        <TextField fx:id="fieldBuscarPlc" prefWidth="200" promptText="Buscar placa..." />

        <Button fx:id="btnNvoVehi" style="-fx-background-color:#2e86de; -fx-text-fill:white;" text="+ Nuevo Vehículo" />

    </HBox>

    <TableView fx:id="tablaVehiculos" VBox.vgrow="ALWAYS">

        <columns>

            <TableColumn fx:id="columID" prefWidth="80" text="ID" />
            <TableColumn fx:id="columPlaca" prefWidth="150" text="Placa" />
            <TableColumn fx:id="columMarca" prefWidth="150" text="Marca" />
            <TableColumn fx:id="columModelo" prefWidth="150" text="Modelo" />
            <TableColumn fx:id="columAnio" prefWidth="120" text="Año" />
            <TableColumn fx:id="btnCliente" prefWidth="250" text="Cliente" />

        </columns>

    </TableView>

    <HBox spacing="10">

        <Button fx:id="btnEditar" text="Editar" style="-fx-background-color:#3498db; -fx-text-fill:white;" />
        <Button fx:id="btnEliminar" style="-fx-background-color:#e74c3c; -fx-text-fill:white;" text="Eliminar" />

    </HBox>

</VBox>
