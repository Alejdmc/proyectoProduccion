<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox spacing="15"
      style="-fx-padding:20; -fx-background-color:#f4f6f8;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.proyectoproduccion.Controlador.OrdenesController">

    <Label text="ÓRDENES DE SERVICIO"
           style="-fx-font-size:22; -fx-font-weight:bold"/>

    <HBox spacing="10">

        <ComboBox fx:id="comboCliente"
                  promptText="Seleccionar Cliente"
                  prefWidth="200"/>

        <ComboBox fx:id="comboVehiculo"
                  promptText="Seleccionar Vehículo"
                  prefWidth="220"/>

        <ComboBox fx:id="comboEstado"
                  promptText="Estado">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="RECIBIDO"/>
                    <String fx:value="EN_PROCESO"/>
                    <String fx:value="ENTREGADO"/>
                </FXCollections>
            </items>
        </ComboBox>

    </HBox>

    <HBox spacing="10">

        <Button text="Agregar Orden"
                onAction="#agregarOrden"
                style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>

        <Button text="Editar Orden"
                onAction="#editarOrden"
                style="-fx-background-color:#3498db; -fx-text-fill:white;"/>

        <Button text="Eliminar Orden"
                onAction="#eliminarOrden"
                style="-fx-background-color:#e74c3c; -fx-text-fill:white;"/>

    </HBox>

    <TableView fx:id="tablaOrdenes"
               onMouseClicked="#seleccionarOrden"
               prefHeight="250">

        <columns>

            <TableColumn fx:id="colId"
                         text="ID"
                         prefWidth="60"/>

            <TableColumn fx:id="colCliente"
                         text="Cliente"
                         prefWidth="180"/>

            <TableColumn fx:id="colVehiculo"
                         text="Vehículo (Placa)"
                         prefWidth="140"/>

            <TableColumn fx:id="colEstado"
                         text="Estado"
                         prefWidth="120"/>

        </columns>

    </TableView>

    <Separator/>

    <Label text="Calculadora de mantenimiento"
           style="-fx-font-size:18; -fx-font-weight:bold"/>

    <HBox spacing="10">

        <TextField fx:id="fieldRepuestos"
                   promptText="Costo repuestos"/>

        <TextField fx:id="fieldHoras"
                   promptText="Horas de trabajo"/>

        <TextField fx:id="fieldCostoHora"
                   promptText="Costo por hora"/>

        <Button text="Calcular Precio"
                onAction="#calcularPrecio"
                style="-fx-background-color:#27ae60; -fx-text-fill:white;"/>

    </HBox>

    <HBox spacing="20">

        <Label text="Mano de obra:"/>
        <Label fx:id="labelManoObra"/>

        <Label text="Subtotal:"/>
        <Label fx:id="labelSubtotal"/>

        <Label text="Total con IVA:"/>
        <Label fx:id="labelTotal"/>

        <Label text="Promedio:"/>
        <Label fx:id="labelPromedio"/>

    </HBox>

</VBox>