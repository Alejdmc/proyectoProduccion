# =====================================================
# EJEMPLO de Configuración de Conexión MySQL
# Sistema de Taller - Proyecto Producción
# =====================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a: database.properties
# 2. Edita los valores según tu configuración de MySQL
# 3. NO subas database.properties a Git (contiene credenciales)
#
# =====================================================

# Host del servidor MySQL
# Ejemplos: localhost, 127.0.0.1, 192.168.1.100
db.host=localhost

# Puerto del servidor MySQL (por defecto 3306)
db.port=3306

# Nombre de la base de datos
db.name=taller_db

# Usuario de MySQL
db.user=root

# Contraseña de MySQL
# IMPORTANTE: Cambia esto por tu contraseña real
# Si no tienes contraseña, deja vacío: db.password=
db.password=TU_PASSWORD_AQUI

# =====================================================
# CONFIGURACIONES COMUNES:
# =====================================================
#
# XAMPP (Windows/Mac):
#   db.host=localhost
#   db.port=3306
#   db.user=root
#   db.password=
#
# MySQL Standalone:
#   db.host=localhost
#   db.port=3306
#   db.user=root
#   db.password=tu_password
#
# Servidor Remoto:
#   db.host=192.168.1.100
#   db.port=3306
#   db.user=admin
#   db.password=password_seguro
#
# =====================================================

