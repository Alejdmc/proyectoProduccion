# =====================================================
# Configuracion de Conexion SQLite
# Sistema de Taller - Proyecto Produccion
# =====================================================

# Tipo de base de datos: mysql o sqlite
db.type=sqlite

# Archivo de base de datos SQLite (solo para sqlite)
db.file=taller_db.sqlite

# =====================================================
# INSTRUCCIONES:
# =====================================================
# 1. SQLite NO necesita servidor, usa un archivo local
# 2. El archivo se creara automaticamente si no existe
# 3. Es ideal para desarrollo local sin instalar MySQL
# 4. Para usar MySQL, cambia db.type=mysql y configura
#    las credenciales correspondientes
# =====================================================

